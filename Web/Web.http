### Variables
@host = http://localhost:5041

### Credentials (seeded by IdentitySeeder)
@adminEmail = admin@local
@adminPassword = Admin123!

###############################################################################
### TestController  GET /api/test  (smoke test)
###############################################################################

GET {{host}}/api/test
Accept: application/json

###

###############################################################################
### AuthController  /api/auth/{login,refresh,revoke,me}
###############################################################################

# @name loginAdmin
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###

# Capture token for the rest of the file
@adminToken = {{loginAdmin.response.body.accessToken}}
@adminRefreshToken = {{loginAdmin.response.body.refreshToken}}

GET {{host}}/api/auth/me
Authorization: Bearer {{adminToken}}
Accept: application/json

###

POST {{host}}/api/auth/refresh
Content-Type: application/json

{
  "accessToken": "{{adminToken}}",
  "refreshToken": "{{adminRefreshToken}}"
}

###

POST {{host}}/api/auth/revoke
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "token": "{{adminRefreshToken}}"
}

###

###############################################################################
### AdminController  /api/admin/*  [Authorize(Roles = "Admin")]
###############################################################################

GET {{host}}/api/admin/users
Authorization: Bearer {{adminToken}}
Accept: application/json

###

# @name createUser01
POST {{host}}/api/admin/users?password=User123!
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "email": "user01@local",
  "firstName": "User",
  "lastName": "One",
  "roles": [ "User" ]
}

###

@user01Id = {{createUser01.response.body.id}}

GET {{host}}/api/admin/users/{{user01Id}}
Authorization: Bearer {{adminToken}}
Accept: application/json

###

PATCH {{host}}/api/admin/users/{{user01Id}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "firstName": "User1",
  "lastName": "Renamed"
}

###

POST {{host}}/api/admin/users/{{user01Id}}/deactivate
Authorization: Bearer {{adminToken}}

###

POST {{host}}/api/admin/users/{{user01Id}}/activate
Authorization: Bearer {{adminToken}}

###

POST {{host}}/api/admin/users/{{user01Id}}/roles
Authorization: Bearer {{adminToken}}
Content-Type: application/json

"SalesManager"

###

DELETE {{host}}/api/admin/users/{{user01Id}}/roles/SalesManager
Authorization: Bearer {{adminToken}}

###

###############################################################################
### PositionsController  /api/positions  (Task 8)
###############################################################################

GET {{host}}/api/positions
Accept: application/json

###

###############################################################################
### TagsController  /api/tags  (Task 8)
###############################################################################

# @name createTagVip
POST {{host}}/api/tags
Content-Type: application/json

{
  "name": "VIP",
  "color": "#FFD700"
}

###

GET {{host}}/api/tags
Accept: application/json

###

# Tag.attach / detach / search-by-tag use a contact id; create one first
# @name createPersonForTag
POST {{host}}/api/contacts
Content-Type: application/json

{
  "contactType": "Person",
  "name": "Piotr Tagtest",
  "email": "piotr.tagtest@example.com",
  "phone": "+48 600 600 600",
  "pesel": "90010100019"
}

###

@tagtestPersonId = {{createPersonForTag.response.body.id}}

POST {{host}}/api/tags/contacts/{{tagtestPersonId}}/VIP

###

DELETE {{host}}/api/tags/contacts/{{tagtestPersonId}}/VIP

###

GET {{host}}/api/tags/contacts/by-tag/VIP
Accept: application/json

###

###############################################################################
### ContactsController  /api/contacts  (polymorphic, discriminator="contactType")
###############################################################################

# @name createOrgPoly
POST {{host}}/api/contacts
Content-Type: application/json

{
  "contactType": "Organization",
  "name": "Fundacja Przyszłość",
  "email": "info@fundacja.pl",
  "phone": "+48 505 505 505"
}

###

@orgId = {{createOrgPoly.response.body.id}}

# @name createCompanyPoly
POST {{host}}/api/contacts
Content-Type: application/json

{
  "contactType": "Company",
  "name": "Acme Corp",
  "email": "contact@acme.pl",
  "phone": "+48 22 000 00 00",
  "nip": "1234567890",
  "regon": "123456789",
  "industry": "IT",
  "website": "https://acme.pl"
}

###

@companyId = {{createCompanyPoly.response.body.id}}

# @name createPersonPoly
POST {{host}}/api/contacts
Content-Type: application/json

{
  "contactType": "Person",
  "name": "Adam Kowalski",
  "email": "adam.kowalski@example.com",
  "phone": "+48 123 456 789",
  "pesel": "90010100019",
  "organizationId": "{{orgId}}",
  "employerId": "{{companyId}}",
  "position": "Developer"
}

###

# Validator in action: Position not in seeded list -> 400
POST {{host}}/api/contacts
Content-Type: application/json

{
  "contactType": "Person",
  "name": "Bad Position Person",
  "email": "bad@example.com",
  "phone": "+48 100 200 300",
  "pesel": "90010100019",
  "position": "Astronaut"
}

###

@personId = {{createPersonPoly.response.body.id}}

GET {{host}}/api/contacts/{{personId}}
Accept: application/json

###

PUT {{host}}/api/contacts/{{personId}}
Content-Type: application/json

{
  "contactType": "Person",
  "name": "Adam Kowalski-Updated",
  "email": "adam.kowalski@example.com",
  "phone": "+48 123 456 789",
  "pesel": "90010100019",
  "organizationId": "{{orgId}}",
  "position": "Senior Developer"
}

###

DELETE {{host}}/api/contacts/{{personId}}

###

