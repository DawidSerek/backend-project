###############################################################################
### InteractionsController  /api/contacts/{contactId}/interactions  [Authorize]
### (polymorphic, discriminator="Type": Email | Sms | Meeting)
###############################################################################

# @name createPersonForInteractions
POST {{host}}/api/contacts
Content-Type: application/json

{
  "contactType": "Person",
  "name": "Ewa Interakcje",
  "email": "ewa@example.com",
  "phone": "+48 700 700 700",
  "pesel": "90010100019"
}

###

@interactionsContactId = {{createPersonForInteractions.response.body.id}}

# Email
POST {{host}}/api/contacts/{{interactionsContactId}}/interactions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "type": "Email",
  "date": "2026-01-15T10:00:00Z",
  "content": "Follow-up email",
  "subject": "Re: meeting",
  "fromAddress": "ewa@example.com",
  "toAddress": "sales@wsei.pl"
}

###

# Sms
POST {{host}}/api/contacts/{{interactionsContactId}}/interactions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "type": "Sms",
  "date": "2026-01-16T14:30:00Z",
  "content": "Reminder about tomorrow",
  "phoneNumber": "+48 700 700 700"
}

###

# Meeting
POST {{host}}/api/contacts/{{interactionsContactId}}/interactions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "type": "Meeting",
  "date": "2026-01-20T09:00:00Z",
  "content": "Onboarding meeting",
  "location": "Wsei Kraków, room 204",
  "endTime": "2026-01-20T10:00:00Z"
}

###

GET {{host}}/api/contacts/{{interactionsContactId}}/interactions?page=1&pageSize=20
Authorization: Bearer {{adminToken}}
Accept: application/json

###

GET {{host}}/api/contacts/{{interactionsContactId}}/interactions?type=Email
Authorization: Bearer {{adminToken}}
Accept: application/json

###

# @name createThrowawayInteraction
POST {{host}}/api/contacts/{{interactionsContactId}}/interactions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "type": "Sms",
  "date": "2026-01-17T08:00:00Z",
  "content": "throwaway",
  "phoneNumber": "+48 700 700 700"
}

###

@throwawayId = {{createThrowawayInteraction.response.body.id}}

DELETE {{host}}/api/interactions/{{throwawayId}}
Authorization: Bearer {{adminToken}}

###

###############################################################################
### DeduplicationController  /api/deduplication/*  [Authorize(Roles="Admin,SalesManager")]
###############################################################################

# @name findDuplicatesExact
POST {{host}}/api/deduplication/find
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "threshold": 1.0,
  "properties": [ "Name" ],
  "strategy": 0
}

###

POST {{host}}/api/deduplication/find
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "threshold": 0.85,
  "properties": [ "Name", "Email" ],
  "strategy": 1
}

###

POST {{host}}/api/deduplication/remove
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "threshold": 0.95,
  "properties": [ "Name" ],
  "strategy": 0
}

###

###############################################################################
### ImportController  /api/import/contacts  (multipart, csv or json)
###############################################################################

POST {{host}}/api/import/contacts
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="contacts.csv"
Content-Type: text/csv

name,email,phoneNumber,pesel,nip
Marek Importowy,mark.import@example.com,+48 600 100 200,90010100019,
Anna Importowa,anna.import@example.com,+48 600 100 201,90010100020,
Import Co,,+48 600 100 202,,1234567890

------WebKitFormBoundary7MA4YWxkTrZu0gW--

###

POST {{host}}/api/import/contacts
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="contacts.json"
Content-Type: application/json

{
  "people": [
    { "name": "Piotr JSON", "email": "piotr.json@example.com", "phoneNumber": "+48 700 100 200", "pesel": "90010100019" }
  ],
  "companies": [
    { "name": "JSON Sp zoo", "email": "office@json.example", "phoneNumber": "+48 700 100 201", "nip": "1234567890" }
  ],
  "organizations": [
    { "name": "JSON Fundacja", "email": "kontakt@jsonfundacja.example", "phoneNumber": "+48 700 100 202" }
  ]
}

------WebKitFormBoundary7MA4YWxkTrZu0gW--

